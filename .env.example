# Dryft — Environment Variables
# Copy this file to .env and fill in real values.
# The .env file must NEVER be committed to git.

# Required: Anthropic API key for the conversation model
ANTHROPIC_API_KEY=your-anthropic-api-key

# Required: Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Required: Your Telegram user ID (get it by sending /whoami to the bot)
# The bot will ONLY respond to this user. No default.
TELEGRAM_USER_ID=your-telegram-user-id

# Optional: Groq API key for voice message transcription (Whisper STT)
# If not set, voice input is disabled. Text still works.
GROQ_API_KEY=your-groq-api-key

# Optional: Tomorrow.io API key for hyperlocal weather
# If not set, weather context injection is disabled.
TOMORROW_API_KEY=your-tomorrow-api-key

# Optional: Path to Google Sheets service account credentials JSON
# If not set, Google Sheets reading is disabled.
GOOGLE_SHEETS_CREDENTIALS=/path/to/google-sheets-service-account.json
